sarb_quarter %>%
select(date, KBP1421K)
m_gdp <- sarb_quarter %>%
select(date, KBP1421K) %>%
mutate(growth = 100 * ((KBP1421K / lag(KBP1421K)) - 1)) %>%
filter(date > "1993-01-01") %>%
