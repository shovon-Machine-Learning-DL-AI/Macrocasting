m_gdp <- sarb_quarter %>%
select(date, KBP1421K) %>%
mutate(growth = 100 * ((KBP1421K / lag(KBP1421K+1)) - 1)) %>%
filter(date > "1993-01-01") %>%
pull(growth) %>%
cpt.mean(., penalty = "SIC", method = "PELT")
plot(
m_gdp,
type = "l",
cpt.col = "blue",
xlab = "Index",
cpt.width = 4
)
# simulate data
sim_var <- c(rnorm(100, 0, 1),
rnorm(50, 0, 2),
rnorm(90, 0, 1),
rnorm(120, 0, 0.5))
plot.ts(sim_var)
v_pelt <- cpt.var(sim_var, method = "PELT")
plot(
v_pelt,
type = "l",
cpt.col = "blue",
xlab = "Index",
cpt.width = 4
)
cpts(v_pelt)
v_gdp <- sarb_quarter %>%
select(date, KBP6006D) %>%
mutate(growth = 100 * ((KBP6006D / lag(KBP6006D)) - 1)) %>%
filter(date > "1960-01-01") %>%
pull(growth) %>%
cpt.var(., method = "PELT")
sim_mv <- c(rnorm(100, 0, 1),
rnorm(50, 1, 2),
rnorm(90, 0, 1),
rnorm(120,-0.8, 0.5))
plot.ts(sim_mv)
# to check for a change in the mean and variance
mv_pelt <- cpt.meanvar(sim_mv, method = "PELT")
plot(mv_pelt)
