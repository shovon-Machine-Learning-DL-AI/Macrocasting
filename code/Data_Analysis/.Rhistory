select(date, KBP6006D) %>%
mutate(growth = 100 * ((KBP6006D / lag(KBP6006D)) - 1)) %>%
filter(date > "1960-01-01") %>%
pull(growth) %>%
cpt.mean(., penalty = "SIC", method = "PELT")
